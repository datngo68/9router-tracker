# Base URL của 9router server.
# Khi deploy lên Cloudflare Pages, set biến môi trường này trong dashboard
# (Settings → Environment variables) thì khách hàng chỉ cần paste API key,
# không phải gõ URL. Giá trị bị bake vào bundle lúc build.
#
# Vd: VITE_API_BASE_URL=https://router.example.com
VITE_API_BASE_URL=

# Tên hiển thị của hệ thống (tuỳ chọn). Hiện ở header dashboard.
VITE_APP_NAME=9Router Key Tracker
